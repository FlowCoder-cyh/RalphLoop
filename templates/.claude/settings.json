{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/scripts/check-ownership.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/scripts/stop-rag-check.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
