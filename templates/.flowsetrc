# FlowSet Configuration
# 프로젝트별 설정 파일

# 프로젝트 정보
PROJECT_NAME=""
PROJECT_TYPE=""         # typescript, python, rust, go, etc.

# 프로젝트 class (v4.0) — Group β/γ/δ 분기의 단일 게이트웨이
#   code    : 코드 생성 중심 (기존 v3.x 동작 = 기본값, 하위 호환)
#   content : 문서/콘텐츠 생성 중심 (CI/PR/hook 선택적 적용)
#   hybrid  : code + content 혼합 (경로별 class 태깅)
# 기존 프로젝트는 이 필드가 없어도 code로 해석되어 동작 완전 동일 (설계 §8 :359).
PROJECT_CLASS="code"

# 실행 모드 (v4.0 WI-B2) — /wi:start Phase 5.95에서 사용자가 선택
#   loop        : flowset.sh 새 터미널 자동 반복 (code class 기본)
#   interactive : 세션 내 WI 1개씩 수동 승인 (content class 기본)
#   team        : lead-workflow 에이전트 spawn, 6단계 (hybrid class 기본)
# 빈 값이면 PROJECT_CLASS에 따라 자동 매핑되어 하위 호환 유지 (code → loop).
EXECUTION_MODE=""

# 루프 제어
MAX_ITERATIONS=50
RATE_LIMIT_PER_HOUR=80
COOLDOWN_SEC=5
ERROR_COOLDOWN_SEC=30
NO_PROGRESS_LIMIT=3

# 워커 토큰 제어
MAX_TURNS=40              # 워커당 최대 턴 수 (탐색 과잉 방지, 0=무제한)

# 파일 경로
PROMPT_FILE=".flowset/PROMPT.md"
FIX_PLAN=".flowset/fix_plan.md"

# 병렬 실행 (1 = 순차, 2+ = 병렬 worktree)
# 병렬 시 같은 batch 내 WI만 동시 처리 (fix_plan.md batch 태그 기반)
PARALLEL_COUNT=1

# 브랜치 규칙
BRANCH_PREFIX="feature"  # feature, fix, chore
COMMIT_PREFIX="WI"       # WI-NNN-[type] 한글 작업명 (NNN = 영숫자 ID, 예: 001, A2a, C3code, E1)

# GitHub 계정 (wi:init Step 4.5에서 설정, wi:start Phase 5.9에서 참조)
GITHUB_ACCOUNT_TYPE=""   # "org" 또는 "personal"
GITHUB_ORG=""            # 조직명 또는 사용자명

# Obsidian Vault 연동 (v3.0)
# 기본 활성화. wi:init에서 연결 확인 후 API_KEY 자동 설정.
# Obsidian 미설치 시 preflight에서 자동 감지 → graceful degradation.
VAULT_ENABLED=true
VAULT_URL="https://localhost:27124"
VAULT_API_KEY=""
VAULT_PROJECT_NAME=""    # PROJECT_NAME과 동일하게 설정
